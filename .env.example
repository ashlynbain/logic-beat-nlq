# Copy to .env in project root or export before starting the backend.
# All keys are optional — the app runs fully offline without them.

# Optional: OpenAI — overrides rule-based params when set (GPT API, not Claude)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: Tavily — web search to enrich vague or reference-heavy prompts
# TAVILY_API_KEY=
